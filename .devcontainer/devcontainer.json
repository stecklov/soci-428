{
    "name": "SOCI-428",
    "build": {"dockerfile": "Dockerfile"},
    "forwardPorts": [8787],
    "portsAttributes": {"8787": {"label": "RStudio", "onAutoForward": "openBrowser", "visibility": "public"}},
    "containerEnv": {"ROOT": "TRUE"},
    "features": {"ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {}},
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "postStartCommand": "rserver --server-daemonize=1 --www-address=0.0.0.0",
    "remoteUser": "root",
    "customizations": {"codespaces": {"openFiles": ["README.md"]}}
  }    