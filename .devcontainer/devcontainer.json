{
  "name": "SOCI-428",
  "image": "rocker/rstudio:4.4",
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "RStudio",
      "onAutoForward": "openBrowser"
    }
  },
  "containerEnv": {
    "DISABLE_AUTH": "true",
    "ROOT": "TRUE"
  },
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {}
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "remoteUser": "rstudio",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    }
  }
}
