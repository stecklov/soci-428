{
  "name": "SOCI-428",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/r-rig:1": {"version": "release"},
    "ghcr.io/rocker-org/devcontainer-features/rstudio-server:0": {"singleUser": true},
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {}
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postAttachCommand": "rserver --www-port=8787 & sleep 3 && sudo service nginx start",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "RStudio",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "customizations": {
    "codespaces": {"openFiles": ["README.md"]}
  }
}
